{
  "changelog": {
    "header": "# Changelog",
    "includeAllCommits": false,
    "sections": [
      { "type": "feat",     "section": "### 🚀 Features",       "hidden": false },
      { "type": "fix",      "section": "### 🐛 Bug Fixes",      "hidden": false },
      { "type": "perf",     "section": "### ⚡ Performance",     "hidden": false },
      { "type": "refactor", "section": "### ♻️ Refactoring",    "hidden": false },
      { "type": "docs",     "section": "### 📝 Documentation",  "hidden": false },
      { "type": "build",    "section": "### 🏗️ Build",          "hidden": true  },
      { "type": "ci",       "section": "### 👷 CI/CD",          "hidden": true  },
      { "type": "chore",    "section": "### 🔧 Chores",         "hidden": true  },
      { "type": "test",     "section": "### ✅ Tests",           "hidden": true  }
    ],
    "otherSection": "### 🔄 Other Changes",
    "linkTemplates": {
      "issueLink": "https://github.com/LabEG/needle-crud/issues/{issue}",
      "commitLink": "https://github.com/LabEG/needle-crud/commit/{commitSha}",
      "versionTagLink": "https://github.com/LabEG/needle-crud/compare/{previousTag}...{currentTag}"
    }
  }
}
