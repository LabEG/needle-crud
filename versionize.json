{
  "$schema": "https://raw.githubusercontent.com/versionize/versionize/master/src/Versionize/versionize-schema.json",
  "changelogOptions": {
    "includeAllCommitsInChangelog": true,
    "skipCommitTypes": ["build", "ci", "style", "test", "chore"],
    "sections": [
      { "type": "feat",     "section": "### 🚀 Features"       },
      { "type": "fix",      "section": "### 🐛 Bug Fixes"      },
      { "type": "perf",     "section": "### ⚡ Performance"     },
      { "type": "refactor", "section": "### ♻️ Refactoring"    },
      { "type": "docs",     "section": "### 📝 Documentation"  },
      { "type": "build",    "section": "### 🏗️ Build"          },
      { "type": "ci",       "section": "### 👷 CI/CD"          }
    ]
  }
}
